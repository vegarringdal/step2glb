ISO-10303-21;
HEADER;
FILE_DESCRIPTION((''),'2;1');
FILE_NAME('bspline_unbounded','',(''),(''),'','','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN'));
ENDSEC;
DATA;
/* Synthetic regression fixture: a flat B-spline patch over [0,10]x[0,10]
   whose only face boundary is a degenerate VERTEX_LOOP (no real trimming
   loop). The patch must tessellate over its whole knot domain via the
   full-domain (unbounded) path instead of being skipped. Area = 100. */
#1=CARTESIAN_POINT('',(0.,0.,0.));
#2=CARTESIAN_POINT('',(5.,0.,0.));
#3=CARTESIAN_POINT('',(10.,0.,0.));
#4=CARTESIAN_POINT('',(0.,5.,0.));
#5=CARTESIAN_POINT('',(5.,5.,0.));
#6=CARTESIAN_POINT('',(10.,5.,0.));
#7=CARTESIAN_POINT('',(0.,10.,0.));
#8=CARTESIAN_POINT('',(5.,10.,0.));
#9=CARTESIAN_POINT('',(10.,10.,0.));
#10=B_SPLINE_SURFACE_WITH_KNOTS('',2,2,((#1,#2,#3),(#4,#5,#6),(#7,#8,#9)),
.UNSPECIFIED.,.F.,.F.,.F.,(3,3),(3,3),(0.,1.),(0.,1.),.UNSPECIFIED.);
#11=VERTEX_POINT('',#1);
#12=VERTEX_LOOP('',#11);
#13=FACE_OUTER_BOUND('',#12,.T.);
#14=ADVANCED_FACE('',(#13),#10,.T.);
#15=CLOSED_SHELL('',(#14));
#16=MANIFOLD_SOLID_BREP('',#15);
ENDSEC;
END-ISO-10303-21;

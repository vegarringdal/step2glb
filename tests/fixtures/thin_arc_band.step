ISO-10303-21;
HEADER;
FILE_DESCRIPTION((''),'2;1');
FILE_NAME('thin_arc_band','',(''),(''),'','','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN'));
ENDSEC;
DATA;
/* Synthetic regression fixture: a planar face bounded by two near-concentric
   arcs (radius 40 and 40.3) over a 60-degree sector -- a 0.3-wide crescent.
   At a coarse deflection the arcs' chords sag deeper than the band is thin
   and the boundary self-intersects, so tess2 fails on the first pass; the
   tessellator must re-discretize finer and recover. Annular-sector area is
   (pi/3)*(40.3^2-40^2)/2 ~= 12.6. */
#1=CARTESIAN_POINT('',(0.,0.,0.));
#2=DIRECTION('',(0.,0.,1.));
#3=DIRECTION('',(1.,0.,0.));
#4=AXIS2_PLACEMENT_3D('',#1,#2,#3);
#5=PLANE('',#4);
#10=CARTESIAN_POINT('',(34.6410161514,-20.,0.));
#11=CARTESIAN_POINT('',(34.6410161514,20.,0.));
#12=CARTESIAN_POINT('',(34.9003537726,20.15,0.));
#13=CARTESIAN_POINT('',(34.9003537726,-20.15,0.));
#14=VERTEX_POINT('',#10);
#15=VERTEX_POINT('',#11);
#16=VERTEX_POINT('',#12);
#17=VERTEX_POINT('',#13);
#20=CIRCLE('',#4,40.);
#21=CIRCLE('',#4,40.3);
#40=DIRECTION('',(0.,1.,0.));
#41=VECTOR('',#40,1.);
#42=LINE('',#11,#41);
#30=EDGE_CURVE('',#14,#15,#20,.T.);
#31=EDGE_CURVE('',#15,#16,#42,.T.);
#32=EDGE_CURVE('',#16,#17,#21,.F.);
#33=EDGE_CURVE('',#17,#14,#42,.T.);
#50=ORIENTED_EDGE('',*,*,#30,.T.);
#51=ORIENTED_EDGE('',*,*,#31,.T.);
#52=ORIENTED_EDGE('',*,*,#32,.T.);
#53=ORIENTED_EDGE('',*,*,#33,.T.);
#60=EDGE_LOOP('',(#50,#51,#52,#53));
#61=FACE_OUTER_BOUND('',#60,.T.);
#62=ADVANCED_FACE('',(#61),#5,.T.);
#63=CLOSED_SHELL('',(#62));
#64=MANIFOLD_SOLID_BREP('',#63);
ENDSEC;
END-ISO-10303-21;

ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('CSG_SOLID minimal example'), '2;1');
FILE_NAME('csg_sample.step', '2026-06-15T07:33:16', ('User'), (''), 'Example', 'AI System', '');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 1 1 1 1 }'));
ENDSEC;
DATA;

/* --- Coordinate System Foundation --- */
#10 = CARTESIAN_POINT('origin', (0.0, 0.0, 0.0));
#11 = DIRECTION('z_axis', (0.0, 0.0, 1.0));
#12 = DIRECTION('x_axis', (1.0, 0.0, 0.0));
#13 = AXIS2_PLACEMENT_3D('base_placement', #10, #11, #12);

#20 = CARTESIAN_POINT('offset_origin', (5.0, 5.0, 0.0));
#21 = AXIS2_PLACEMENT_3D('cylinder_placement', #20, #11, #12);

/* --- Constructive Solid Geometry Primitives --- */
/* A block placed at the origin with dimensions DX=10, DY=10, DZ=10 */
#30 = BLOCK('base_block', #13, 10.0, 10.0, 10.0);

/* A cylinder placed at the offset origin with Height=10 and Radius=3 */
#31 = RIGHT_CIRCULAR_CYLINDER('cutting_cylinder', #21, 10.0, 3.0);

/* --- Boolean Operation --- */
/* Subtract the cylinder from the block using .DIFFERENCE. */
#40 = BOOLEAN_RESULT('hole_operation', .DIFFERENCE., #30, #31);

/* --- The Final CSG Solid Definition --- */
/* This designates the boolean result as the final volumetric part */
#50 = CSG_SOLID('final_part', #40);

ENDSEC;
END-ISO-10303-21;